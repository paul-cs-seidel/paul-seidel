{
  "name": "paul-seidel-com",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Paul Seidel — Portfolio. Sauberer Ausgangszustand: Navbar, Seiten, sauberer Seitenwechsel.",
  "scripts": {
    "dev": "npm run prerender && vite",
    "prerender": "node scripts/prerender.mjs",
    "build": "npm run prerender && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "qa": "npm run format:check && npm run lint && npm run lint:css && npm run build && npm run test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@csstools/postcss-global-data": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "postcss-custom-media": "^12.0.1",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "split-type": "^0.3.4",
    "three": "^0.184.0"
  }
}
