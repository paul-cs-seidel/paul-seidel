# Beispiel-Umgebungsvariablen — kopieren nach `.env` und ausfüllen.
# Nur mit dem Präfix VITE_ benannte Variablen landen im Client-Bundle.
# `.env` selbst ist gitignored und gehört NICHT ins Repo.

# Öffentliche Basis-URL der Seite (für Canonical / Open Graph / Sitemap).
VITE_SITE_URL=https://paul-seidel.com

# ── Kontaktformular (geplant, Cloudflare Pages Functions) ──────────────────
# Noch nicht aktiv — Platzhalter für die spätere Formular-Phase.
# Öffentlicher Turnstile-Site-Key (Client):
# VITE_TURNSTILE_SITE_KEY=
# Server-seitige Secrets (NUR in der Hosting-Umgebung setzen, nie committen):
# TURNSTILE_SECRET_KEY=
# CONTACT_TO_EMAIL=info@paul-seidel.com
# RESEND_API_KEY=
